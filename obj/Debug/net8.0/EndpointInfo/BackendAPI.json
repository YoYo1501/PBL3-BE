{
  "openapi": "3.0.1",
  "info": {
    "title": "BackendAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Registrations": {
      "post": {
        "tags": [
          "Registrations"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegistrationRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "get": {
        "tags": [
          "Registrations"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Registrations/pending": {
      "get": {
        "tags": [
          "Registrations"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Registrations/{id}/approve": {
      "put": {
        "tags": [
          "Registrations"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRegistrationDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRegistrationDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveRegistrationDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Room": {
      "get": {
        "tags": [
          "Room"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Room/{id}": {
      "get": {
        "tags": [
          "Room"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApproveRegistrationDto": {
        "type": "object",
        "properties": {
          "isApproved": {
            "type": "boolean",
            "default": true
          },
          "rejectionReason": {
            "type": "string",
            "default": "Hồ sơ hợp lệ",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "default": "admin@ktx.edu.vn",
            "nullable": true
          },
          "password": {
            "type": "string",
            "default": "Admin@123",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegistrationRequestDto": {
        "type": "object",
        "properties": {
          "fullName": {
            "type": "string",
            "default": "Trần Văn B",
            "nullable": true
          },
          "citizenId": {
            "type": "string",
            "default": "048201002345",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "default": "Nam",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "default": "0987654321",
            "nullable": true
          },
          "email": {
            "type": "string",
            "default": "studentb@gmail.com",
            "nullable": true
          },
          "permanentAddress": {
            "type": "string",
            "default": "456 Đường XYZ, Hà Nội",
            "nullable": true
          },
          "roomId": {
            "type": "integer",
            "format": "int32",
            "default": 1
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  }
}